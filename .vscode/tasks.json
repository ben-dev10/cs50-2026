{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc build active file",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-lcs50"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "label":"Start Jupyter (cling-env)",
            "type": "shell",
            "command":"source ~/miniconda3/etc/profile.d/conda.sh && conda activate cling-env && jupyter lab --no-browser",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
            },
            "isBackground": true,
            "problemMatcher":[],
        }
    ],
    "version": "2.0.0"
}